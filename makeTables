DROP TABLE Orders;
DROP TABLE Product;
DROP TABLE Customer;
DROP TABLE Employee;


CREATE TABLE Employee(
EmpID INT(3) PRIMARY KEY AUTO_INCREMENT, 
Name CHAR(20) NOT NULL,
Password CHAR(20) NOT NULL);

CREATE TABLE Customer(
UserID INT(3) PRIMARY KEY AUTO_INCREMENT, 
Name CHAR(30) NOT NULL, 
Email CHAR(40) NOT NULL,
Password CHAR(20) NOT NULL);

CREATE TABLE Product(
ProductID INT(3) PRIMARY KEY AUTO_INCREMENT, 
Name CHAR(20) NOT NULL, 
Description CHAR(120),
Price DECIMAL(6,2) NOT NULL, 
Stock INT(5) NOT NULL);

CREATE TABLE Orders(
OrderID INT(3) PRIMARY KEY AUTO_INCREMENT, 
UserID INT(3) NOT NULL, 
EmpID INT(3),  
Status CHAR(10) NOT NULL, 
ShippingAddr CHAR(30), 
BillingInfo CHAR(16), 
FOREIGN KEY (UserID) REFERENCES Customer(UserID), 
FOREIGN KEY (EmpID) REFERENCES Employee(EmpID));

CREATE TABLE OrderItem(
OrderID INT(3),
ProductID INT(3),
Quantity INT(3) NOT NULL,
PRIMARY KEY (OrderID, ProductID),
FOREIGN KEY(OrderID) REFERENCES Orders(OrderID),
FOREIGN KEY(ProductID) REFERENCES Product(ProductID));

CREATE TABLE Cart(
CartID INT(3) PRIMARY KEY AUTO_INCREMENT,
UserID INT(3) NOT NULL,
FOREIGN KEY (UserID) REFERENCES Customer(UserID));

CREATE TABLE CartItem(
CartID INT(3),
ProductID INT(3),
Quantity INT(3) NOT NULL,
PRIMARY KEY (CartID, ProductID),
FOREIGN KEY(CartID) REFERENCES Cart(CartID),
FOREIGN KEY(ProductID) REFERENCES Product(ProductID));



